# Same Day Solution — POS Partner API Portal
# Copy this file to .env.local and fill in your real credentials
# NEVER commit .env.local to version control

API_BASE_URL=https://api.samedaysolution.in
# Must include payout (or all) permission for Settlement / payout APIs — not only POS
API_KEY=pk_live_YOUR_API_KEY_HERE
API_SECRET=sk_live_YOUR_API_SECRET_HERE

# Payout (Settlement) — Same Day merchant id (internal retailers.partner_id); sent as merchant_id to the API (v2.1+; legacy alias retailer_id)
PAYOUT_PARTNER_ID=YOUR_MERCHANT_ID

# Password gate for Settlement/Payout dashboard — leave empty or remove to disable
SETTLEMENT_PASSWORD=
