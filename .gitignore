# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit real credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example is safe to commit (has placeholder values only)
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / editor
.vscode/
*.code-workspace
.idea/

# uploaded assets (may contain sensitive receipt images)
/assets/

# embedded repos / subfolders
/portal/

# OS
Desktop.ini
._*
