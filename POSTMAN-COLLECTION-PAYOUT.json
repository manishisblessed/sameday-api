            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-api-key", "value": "{{api_key}}" },
              { "key": "x-signature", "value": "auto-generated" },
              { "key": "x-timestamp", "value": "auto-generated" }
            ],
            "url": {
              "raw": "{{base_url}}/api/partner/payout/status?transactionId={{last_payout_transaction_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "partner", "payout", "status"],
              "query": [
                { "key": "transactionId", "value": "{{last_payout_transaction_id}}", "description": "Internal row UUID (auto-set after successful Initiate Transfer)" },
                { "key": "clientRefId", "value": "", "description": "Client reference ID from transfer (enable and disable transactionId to use this)", "disabled": true }
              ]
            },
            "description": "Check status of a single payout transfer.\n\nFor pending/processing transactions, the API auto-checks with the provider and updates status.\nFailed transactions are auto-refunded.\n\n### Query Parameters\n| Param | Type | Required | Description |\n|-------|------|----------|-------------|\n| `transactionId` | String | Conditional | Our internal transaction UUID |\n| `clientRefId` | String | Conditional | Client ref ID from transfer |\n\nAt least one of `transactionId` or `clientRefId` is required.\n\n**Tip:** After a successful **Initiate Transfer**, `last_payout_transaction_id` is saved for this request."
          },
          "response": [
            {
              "name": "200 — Status",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"transaction\": {\n    \"id\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n    \"client_ref_id\": \"PAYOUT-...\",\n    \"provider_txn_id\": \"UTR123456789\",\n    \"rrn\": \"987654321012\",\n    \"status\": \"SUCCESS\",\n    \"amount\": 1000,\n    \"charges\": 0,\n    \"total_amount\": 1000,\n    \"account_number\": \"************3456\",\n    \"account_holder_name\": \"John Doe\",\n    \"bank_name\": \"HDFC Bank\",\n    \"transfer_mode\": \"IMPS\",\n    \"created_at\": \"2026-04-10T10:00:00.000Z\",\n    \"completed_at\": \"2026-04-10T10:01:00.000Z\"\n  }\n}"
            },
            {
              "name": "404 — Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"NOT_FOUND\",\n    \"message\": \"Transaction not found\"\n  }\n}"
            }
          ]
        },
        {
          "name": "List My Transfers",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const CryptoJS = require('crypto-js');",
                  "let apiKey = pm.collectionVariables.get('api_key');",
                  "let apiSecret = pm.collectionVariables.get('api_secret');",
                  "if (!apiKey) apiKey = pm.environment.get('api_key');",
                  "if (!apiSecret) apiSecret = pm.environment.get('api_secret');",
                  "const placeholderKey = 'pk_live_YOUR_API_KEY_HERE';",
                  "const placeholderSecret = 'sk_live_YOUR_API_SECRET_HERE';",
                  "if (!apiKey || apiKey.trim() === '' || apiKey === placeholderKey) { throw new Error('Set api_key in Collection Variables (or Environment).'); }",
                  "if (!apiSecret || apiSecret.trim() === '' || apiSecret === placeholderSecret) { throw new Error('Set api_secret in Collection Variables (or Environment).'); }",
                  "const timestamp = Date.now().toString();",
                  "const signature = CryptoJS.HmacSHA256('' + timestamp, apiSecret).toString(CryptoJS.enc.Hex);",
                  "pm.request.headers.upsert({ key: 'x-api-key', value: apiKey });",
                  "pm.request.headers.upsert({ key: 'x-signature', value: signature });",
                  "pm.request.headers.upsert({ key: 'x-timestamp', value: timestamp });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
                  "const j = pm.response.json();",
                  "pm.test('Has transactions array', function() { pm.expect(j.success).to.be.true; pm.expect(j.transactions).to.be.an('array'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-api-key", "value": "{{api_key}}" },
              { "key": "x-signature", "value": "auto-generated" },
              { "key": "x-timestamp", "value": "auto-generated" }
            ],
            "url": {
              "raw": "{{base_url}}/api/partner/payout/status?list=true",
              "host": ["{{base_url}}"],
              "path": ["api", "partner", "payout", "status"],
              "query": [
                { "key": "list", "value": "true", "description": "Return list of recent transactions" }
              ]
            },
            "description": "Get list of your recent payout transactions (last 20).\n\n### Query Parameters\n| Param | Type | Required | Description |\n|-------|------|----------|-------------|\n| `list` | Boolean | ✅ Yes | Must be `true` |"
          },
          "response": [
            {
              "name": "200 — List",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"transactions\": [\n    {\n      \"id\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n      \"client_ref_id\": \"PAYOUT-...\",\n      \"amount\": 1000,\n      \"charges\": 0,\n      \"status\": \"SUCCESS\",\n      \"transfer_mode\": \"IMPS\",\n      \"created_at\": \"2026-04-10T10:00:00.000Z\"\n    }\n  ]\n}"
            }
          ]
        }
      ]
    }
  ]
