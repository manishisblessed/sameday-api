        {
          "name": "Initiate Transfer",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const CryptoJS = require('crypto-js');",
                  "let apiKey = pm.collectionVariables.get('api_key');",
                  "let apiSecret = pm.collectionVariables.get('api_secret');",
                  "if (!apiKey) apiKey = pm.environment.get('api_key');",
                  "if (!apiSecret) apiSecret = pm.environment.get('api_secret');",
                  "const placeholderKey = 'pk_live_YOUR_API_KEY_HERE';",
                  "const placeholderSecret = 'sk_live_YOUR_API_SECRET_HERE';",
                  "if (!apiKey || apiKey.trim() === '' || apiKey === placeholderKey) { throw new Error('Set api_key in Collection Variables (or Environment).'); }",
                  "if (!apiSecret || apiSecret.trim() === '' || apiSecret === placeholderSecret) { throw new Error('Set api_secret in Collection Variables (or Environment).'); }",
                  "const timestamp = Date.now().toString();",
                  "const body = JSON.parse(pm.request.body.raw);",
                  "const signaturePayload = JSON.stringify(body) + timestamp;",
                  "const signature = CryptoJS.HmacSHA256(signaturePayload, apiSecret).toString(CryptoJS.enc.Hex);",
                  "pm.request.headers.upsert({ key: 'x-api-key', value: apiKey });",
                  "pm.request.headers.upsert({ key: 'x-signature', value: signature });",
                  "pm.request.headers.upsert({ key: 'x-timestamp', value: timestamp });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Response is JSON with success field', function() { pm.response.to.be.json; const j = pm.response.json(); pm.expect(j).to.have.property('success'); });",
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  pm.test('Transfer accepted', function() { pm.expect(j.success).to.be.true; pm.expect(j.transaction_id).to.be.a('string'); });",
                  "  if (j.success && j.transaction_id) {",
                  "    pm.collectionVariables.set('last_payout_transaction_id', j.transaction_id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{api_key}}" },
              { "key": "x-signature", "value": "auto-generated" },
              { "key": "x-timestamp", "value": "auto-generated" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountNumber\": \"1234567890123456\",\n  \"ifscCode\": \"HDFC0001234\",\n  \"accountHolderName\": \"John Doe\",\n  \"amount\": 1000,\n  \"transferMode\": \"IMPS\",\n  \"bankId\": 1,\n  \"bankName\": \"HDFC Bank\",\n  \"beneficiaryMobile\": \"9876543210\",\n  \"senderName\": \"Partner Company\",\n  \"senderMobile\": \"9876543211\",\n  \"senderEmail\": \"partner@example.com\",\n  \"remarks\": \"Payout\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/partner/payout/transfer",
              "host": ["{{base_url}}"],
              "path": ["api", "partner", "payout", "transfer"]
            },
            "description": "Initiate IMPS or NEFT transfer. Debits your **partner wallet** (amount + charges).\n\n### Request Body\n| Field | Type | Required | Description |\n|-------|------|----------|-------------|\n| `accountNumber` | String | ✅ Yes | Beneficiary account number |\n| `ifscCode` | String | ✅ Yes | IFSC code |\n| `accountHolderName` | String | ✅ Yes | Beneficiary name |\n| `amount` | Number | ✅ Yes | Amount in rupees |\n| `transferMode` | String | ✅ Yes | `IMPS` or `NEFT` |\n| `bankId` | Number | ✅ Yes | Bank ID from bank list |\n| `bankName` | String | ✅ Yes | Bank name |\n| `beneficiaryMobile` | String | ✅ Yes | 10-digit mobile (6-9 start) |\n| `senderName` | String | ✅ Yes | Sender name |\n| `senderMobile` | String | ✅ Yes | 10-digit mobile (6-9 start) |\n| `senderEmail` | String | No | Sender email |\n| `remarks` | String | No | Transfer remarks |\n\n### Duplicate Prevention\nSame account within 2 minutes returns 429. Wait before retrying.\n\n### On Failure\nWallet is automatically refunded."
          },
          "response": [
            {
              "name": "200 — Transfer Initiated",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Transfer initiated successfully\",\n  \"transaction_id\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"provider_txn_id\": \"UTR123456789\",\n  \"client_ref_id\": \"PAYOUT-...\",\n  \"status\": \"PROCESSING\",\n  \"amount\": 1000,\n  \"charges\": 0,\n  \"total_debited\": 1000,\n  \"account_number\": \"************3456\",\n  \"account_holder_name\": \"John Doe\",\n  \"bank_name\": \"HDFC Bank\",\n  \"transfer_mode\": \"IMPS\"\n}"
            },
            {
              "name": "400 — Insufficient Balance",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INSUFFICIENT_BALANCE\",\n    \"message\": \"Insufficient partner wallet balance\"\n  },\n  \"wallet_balance\": 500,\n  \"amount\": 1000,\n  \"charges\": 0,\n  \"total_required\": 1000\n}"
            },
            {
              "name": "403 — Wallet Frozen",
              "status": "Forbidden",
              "code": 403,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"WALLET_FROZEN\",\n    \"message\": \"Partner wallet is frozen: Pending verification\"\n  }\n}"
            },
            {
              "name": "429 — Duplicate Prevention",
              "status": "Too Many Requests",
              "code": 429,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"DUPLICATE\",\n    \"message\": \"Transaction to this account initiated 45s ago. Wait 75s.\"\n  },\n  \"duplicate_prevention\": true,\n  \"wait_seconds\": 75\n}"
            }
          ]
        },
        {
          "name": "Get Transfer Status",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const CryptoJS = require('crypto-js');",
