          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-api-key", "value": "{{api_key}}" },
              { "key": "x-signature", "value": "auto-generated" },
              { "key": "x-timestamp", "value": "auto-generated" }
            ],
            "url": {
              "raw": "{{base_url}}/api/partner/payout/banks",
              "host": ["{{base_url}}"],
              "path": ["api", "partner", "payout", "banks"],
              "query": [
                { "key": "imps", "value": "true", "description": "IMPS-enabled banks only", "disabled": true },
                { "key": "neft", "value": "true", "description": "NEFT-enabled banks only", "disabled": true },
