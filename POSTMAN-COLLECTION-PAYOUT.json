            "description": "Returns list of banks for payout. Use `bankId` and `bankName` in Verify and Transfer.\n\n### Query Parameters\n| Param | Type | Description |\n|-------|------|-------------|\n| `imps` | Boolean | IMPS-enabled banks only |\n| `neft` | Boolean | NEFT-enabled banks only |\n| `popular` | Boolean | Popular banks only |\n| `search` | String | Search by bank name |"
          },
          "response": [
            {
              "name": "200 — Banks",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"banks\": [\n    { \"id\": 1, \"name\": \"HDFC Bank\", \"imps\": true, \"neft\": true },\n    { \"id\": 2, \"name\": \"State Bank of India\", \"imps\": true, \"neft\": true }\n  ],\n  \"total\": 100,\n  \"imps_enabled\": 95,\n  \"neft_enabled\": 98\n}"
            },
            {
              "name": "401 — Unauthorized (IP Blocked)",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"UNAUTHORIZED\",\n    \"message\": \"IP address 203.0.113.50 is not authorized. Please contact admin to whitelist your server IP.\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Verify Bank Account",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const CryptoJS = require('crypto-js');",
                  "let apiKey = pm.collectionVariables.get('api_key');",
                  "let apiSecret = pm.collectionVariables.get('api_secret');",
                  "if (!apiKey) apiKey = pm.environment.get('api_key');",
                  "if (!apiSecret) apiSecret = pm.environment.get('api_secret');",
                  "const placeholderKey = 'pk_live_YOUR_API_KEY_HERE';",
                  "const placeholderSecret = 'sk_live_YOUR_API_SECRET_HERE';",
                  "if (!apiKey || apiKey.trim() === '' || apiKey === placeholderKey) { throw new Error('Set api_key in Collection Variables (or Environment).'); }",
                  "if (!apiSecret || apiSecret.trim() === '' || apiSecret === placeholderSecret) { throw new Error('Set api_secret in Collection Variables (or Environment).'); }",
                  "const timestamp = Date.now().toString();",
                  "const body = JSON.parse(pm.request.body.raw);",
                  "const signaturePayload = JSON.stringify(body) + timestamp;",
                  "const signature = CryptoJS.HmacSHA256(signaturePayload, apiSecret).toString(CryptoJS.enc.Hex);",
                  "pm.request.headers.upsert({ key: 'x-api-key', value: apiKey });",
                  "pm.request.headers.upsert({ key: 'x-signature', value: signature });",
                  "pm.request.headers.upsert({ key: 'x-timestamp', value: timestamp });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 400', function() { pm.expect([200, 400]).to.include(pm.response.code); });",
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.success).to.be.true;",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{api_key}}" },
              { "key": "x-signature", "value": "auto-generated" },
              { "key": "x-timestamp", "value": "auto-generated" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountNumber\": \"1234567890123456\",\n  \"ifscCode\": \"HDFC0001234\",\n  \"bankName\": \"HDFC Bank\",\n  \"bankId\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/partner/payout/verify",
              "host": ["{{base_url}}"],
              "path": ["api", "partner", "payout", "verify"]
            },
            "description": "Verify bank account and get beneficiary name. Penniless transaction (no charges).\n\n### Request Body\n| Field | Type | Required | Description |\n|-------|------|----------|-------------|\n| `accountNumber` | String | ✅ Yes | Bank account number |\n| `ifscCode` | String | ✅ Yes | IFSC code |\n| `bankName` | String | No | Bank name |\n| `bankId` | Number | No | Bank ID from bank list |"
          },
          "response": [
